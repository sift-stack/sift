#!/usr/bin/env bash

usage() {
  cat<<EOT
Various development utilities.

Each subcommand runs against the project's uv-managed environment.
Bootstrap with './scripts/dev bootstrap' on a fresh checkout (requires uv
installed: https://docs.astral.sh/uv/#installation).

Usage: dev [SUBCOMMAND] [OPTIONS]

Subcommands:
  bootstrap        Create .venv and install all dev dependencies via uv
  docs             Boots up documentation server on port 8080
  docs-build       Builds docs and emits to docs/sift_py
  fmt              Runs 'ruff format'
  lint-fix         Runs 'ruff check --fix'
  lint             Runs 'ruff check'
  mypy             Runs 'mypy lib' for static analysis
  mypy-win         Runs 'mypy --platform=win32 lib' (Windows compat check)
  pyright          Runs 'pyright lib' for type checking
  check            Runs lint-fix, fmt, mypy, mypy-win, pyright sequentially
  gen-stubs        Generates pyi stubs for sift_client synchronous wrappers
  gen-extras       Generates [project.optional-dependencies]
  mypy-stubs       Runs stubtest (mypy) on the generated pyi stubs
  pip-install      Re-install project dependencies (alias for 'uv sync --extra dev-all')
  test             Execute non-integration tests against the project's Python
  test-floor       Execute non-integration tests against the floor Python (3.8)
  test-ceiling     Execute non-integration tests against the ceiling Python (3.14)
  test-integration Execute integration tests
  test-all         Execute all tests

Options:
  -h, --help     Print usage text
EOT
}

pip_install() {
  uv sync --extra dev-all
}

bootstrap() {
  # Sweep any stale venv from the legacy pip-based setup so editor configs
  # don't keep pointing at it.
  rm -rf venv build lib/sift_stack_py.egg-info
  uv sync --extra dev-all
}

run_mypy() {
  uv run mypy lib
}

run_mypy_win() {
  # Re-run mypy with --platform=win32 so typeshed evaluates platform-gated
  # stubs (e.g. fcntl) as if we were on Windows. Catches imports that would
  # only fail at runtime on Windows. The library ships to PyPI for all
  # platforms, so Windows-specific import bugs need to fail CI too.
  uv run mypy --platform=win32 lib
}

run_pyright() {
  uv run pyright lib
}

run_checks() {
  lint_fix
  fmt
  run_mypy
  run_mypy_win
  run_pyright
}

fmt() {
  uv run ruff format
}

lint() {
  uv run ruff check
}

lint_fix() {
  uv run ruff check --fix
}

doc() {
  uv run mkdocs serve
}

doc_build() {
  uv run mkdocs build
}

run_tests() {
  uv run pytest -m "not integration"
}

run_tests_floor() {
  # uv auto-downloads a managed Python 3.8 (via python-build-standalone) on
  # first run. `--no-project --with-editable '.[dev-all]'` resolves the
  # project + dev-all extra ad hoc under 3.8, installing the project
  # editable so pytest collects from the working tree.
  uv run --python 3.8 --no-project --with-editable '.[dev-all]' pytest -m "not integration"
}

run_tests_ceiling() {
  # Symmetric to test-floor: runs against the highest officially supported
  # Python version (per the `Programming Language :: Python :: 3.14`
  # classifier in pyproject.toml). uv downloads the interpreter on first
  # run. Catches forward-compat issues (deprecated APIs, removed stdlib
  # modules) the same way test-floor catches floor-version regressions.
  uv run --python 3.14 --no-project --with-editable '.[dev-all]' pytest -m "not integration"
}

run_tests_integration() {
  uv run pytest -m "integration"
}

run_tests_all() {
  uv run pytest
}


gen_stubs() {
  cd lib
  uv run python sift_client/_internal/gen_pyi.py sift_client/resources/sync_stubs
  cd ..
  uv run ruff format ./lib/sift_client/resources/sync_stubs/*.pyi -q
  uv run ruff check ./lib/sift_client/resources/sync_stubs/*.pyi --fix --unsafe-fixes -q
}

mypy_stubs() {
  cd lib
  uv run stubtest sift_client.resources.sync_stubs
}

gen_extras() {
  cd scripts
  uv run python generate_extras.py
  cd ..
}

shift "$((OPTIND - 1))"

case "$1" in
    -h | --help)
        usage
        exit 0
        ;;
    bootstrap)
        bootstrap
        ;;
    docs-build)
        doc_build
        ;;
    docs)
        doc
        ;;
    pip-install)
        pip_install
        ;;
    fmt)
        fmt
        ;;
    lint-fix)
        lint_fix
        ;;
    lint)
        lint
        ;;
    mypy)
        run_mypy
        ;;
    mypy-win)
        run_mypy_win
        ;;
    pyright)
        run_pyright
        ;;
    check)
        run_checks
        ;;
    test)
        run_tests
        ;;
    test-floor)
        run_tests_floor
        ;;
    test-ceiling)
        run_tests_ceiling
        ;;
    test-integration)
        run_tests_integration
        ;;
    test-all)
        run_tests_all
        ;;
    gen-stubs)
        gen_stubs
        ;;
    gen-extras)
        gen_extras
        ;;
    mypy-stubs)
        mypy_stubs
        ;;
    update-dev)
        echo "update-dev is no longer needed under uv; just run './scripts/dev <subcommand>' directly."
        exit 1
        ;;
    "")
        echo "No subcommand provided"
        usage
        exit 1
        ;;
    *)
        echo "Invalid subcommand: $1"
        usage
        exit 1
        ;;
esac

# Leave the script's exit code as the subcommand's. A trailing `exit 0` here
# silently masked ruff / mypy / pytest failures from the pre-push hook.
